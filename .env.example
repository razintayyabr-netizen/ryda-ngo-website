# ─── RYDA NGO Website — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values.
# On Vercel, set these in: Settings → Environment Variables

# ── Vercel KV (auto-populated when you link a KV store in Vercel dashboard) ──
# Do NOT set these manually if using Vercel KV — Vercel sets them automatically.
KV_REST_API_URL=your_kv_url_here
KV_REST_API_TOKEN=your_kv_token_here
KV_REST_API_READ_ONLY_TOKEN=your_kv_read_only_token_here

# ── Writer Access Token ───────────────────────────────────────────────────────
# Set a strong secret that writers will use to log into the Writer Panel.
# Minimum 16 characters recommended. Keep this private.
# Example: openssl rand -hex 24
WRITER_TOKEN=12345678
