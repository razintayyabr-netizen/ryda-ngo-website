rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Posts collection - public read, write requires auth token in request
    match /posts/{postId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null || request.resource.data.writerToken == 'RYDA5555';
    }
    
    // Uploads metadata
    match /uploads/{uploadId} {
      allow read: if true;
      allow create: if request.auth != null || request.resource.data.writerToken == 'RYDA5555';
    }
  }
}
